APP_NAME=TowMate
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://jarztowing.up.railway.app

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically; alternatively set individual vars.
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=sync

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="TowMate"

# ── Super Admin seed (used by migration & SuperAdminSeeder) ───────────────────
SUPERADMIN_EMAIL=superadmin@gmail.com
SUPERADMIN_PASSWORD=admin123456
SUPERADMIN_NAME=System SuperAdmin

# ── PayMongo ──────────────────────────────────────────────────────────────────
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=

# ── Google Maps (optional — falls back to OpenRouteService) ──────────────────
GOOGLE_MAPS_API_KEY=
